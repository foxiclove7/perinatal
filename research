<script>
    // ================================================================
    // НАСТРОЙКА: URL вашего Google Apps Script
    // ================================================================
    const SCRIPT_URL = 'https://script.google.com/macros/s/ЗАМЕНИТЕ_НА_ВАШ_URL/exec';

    // ================================================================
    // ОБРАБОТКА ОТПРАВКИ
    // ================================================================
    document.getElementById('surveyForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        const status = document.getElementById('status');
        btn.disabled = true;
        btn.textContent = '⏳ Отправка...';
        status.className = 'status';
        status.textContent = '';

        // --- 1. Собираем данные ---
        const formData = new FormData(this);
        const data = {};

        // Демография
        data.age = document.getElementById('age').value || '';
        data.gestation = document.getElementById('gestation').value || '';
        data.marital = formData.get('marital') || '';
        data.education = formData.get('education') || '';
        data.income = formData.get('income') || '';
        data.pregnancy_number = formData.get('pregnancy_number') || '';
        data.children_count = formData.get('children_count') || '';
        data.planned = formData.get('planned') || '';
        data.denomination = formData.get('denomination') || '';
        data.church_attendance = formData.get('church_attendance') || '';
        data.prayer_frequency = formData.get('prayer_frequency') || '';
        data.communion = formData.get('communion') || '';
        data.fasting = formData.get('fasting') || '';
        data.believer = formData.get('believer') || '';
        data.role_of_faith = formData.get('role_of_faith') || '';
        data.spouse_religion = formData.get('spouse_religion') || '';
        data.abortion_thoughts = formData.get('abortion_thoughts') || '';

        // Чекбоксы (былое)
        let past = [];
        if (document.getElementById('miscarriages').checked) past.push('miscarriages');
        if (document.getElementById('abortion').checked) past.push('abortion');
        if (document.getElementById('medical_abortion').checked) past.push('medical_abortion');
        if (document.getElementById('none_past').checked) past.push('none');
        data.past_events = past.join(',');

        // --- 2. Собираем ТОБ (10 вопросов) ---
        const tobValues = [];
        for (let i = 1; i <= 10; i++) {
            const val = formData.get('tob' + i);
            if (val) tobValues.push(parseInt(val));
        }
        // Подсчет типа ПКГД по Добрякову (упрощенный алгоритм)
        // Для демонстрации: сумма баллов
        const tobSum = tobValues.reduce((a, b) => a + b, 0);
        // Оптимальный: 10–25, Тревожный: 26–35, Эйфорический: 36–45, Игнорирующий: 46–50
        let tobType = 'unknown';
        if (tobSum >= 10 && tobSum <= 25) tobType = 'optimal';
        else if (tobSum >= 26 && tobSum <= 35) tobType = 'anxious';
        else if (tobSum >= 36 && tobSum <= 45) tobType = 'euphoric';
        else if (tobSum >= 46 && tobSum <= 50) tobType = 'ignoring';
        data.tob_type = tobType;

        // --- 3. Собираем MAAS (6 вопросов) ---
        const maasValues = [];
        for (let i = 1; i <= 6; i++) {
            const val = formData.get('maas' + i);
            if (val) maasValues.push(parseInt(val));
        }
        const maasTotal = maasValues.reduce((a, b) => a + b, 0);
        data.maas_total = maasTotal;
        // Для шкалы качества и поведения (условно)
        data.maas_quality = maasTotal; // упрощенно
        data.maas_behavior = maasTotal; // упрощенно

        // --- 4. Собираем религиозную ориентацию ---
        const intVals = [];
        const extVals = [];
        for (let i = 1; i <= 4; i++) {
            const v = formData.get('relig_int' + i);
            if (v) intVals.push(parseInt(v));
        }
        for (let i = 1; i <= 2; i++) {
            const v = formData.get('relig_ext' + i);
            if (v) extVals.push(parseInt(v));
        }
        data.relig_intrinsic = intVals.reduce((a, b) => a + b, 0);
        data.relig_extrinsic = extVals.reduce((a, b) => a + b, 0);

        // --- 5. Группа (определяем по критериям) ---
        let group = 'other';
        const isOrthodox = data.denomination === 'orthodox';
        const churchFreq = data.church_attendance;
        const communionFreq = data.communion;
        const prayerFreq = data.prayer_frequency;

        // Воцерковленная: православие + храм ≥1раз/мес + причастие регулярно + молитва ежедневно
        if (isOrthodox && 
            (churchFreq === 'weekly_plus' || churchFreq === '2_3_month' || churchFreq === '1_month') &&
            communionFreq === 'regularly' &&
            (prayerFreq === 'daily_several' || prayerFreq === 'daily_once')) {
            group = 'practicing_orthodox';
        }
        // Невоцерковленная: православие + храм редко + молитва редко
        else if (isOrthodox && 
            (churchFreq === '1_2_year' || churchFreq === 'never') &&
            (prayerFreq === 'never' || prayerFreq === 'holidays_difficult')) {
            group = 'non_practicing';
        }
        // Протестантка-баптистка
        else if (data.denomination === 'protestant_baptist' && 
            (churchFreq === 'weekly_plus' || churchFreq === '2_3_month') &&
            communionFreq === 'regularly' &&
            (prayerFreq === 'daily_several' || prayerFreq === 'daily_once')) {
            group = 'baptist';
        }
        data.group = group;

        // --- 6. Отправка ---
        fetch(SCRIPT_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(() => {
            status.className = 'status success';
            status.textContent = '✅ Спасибо! Ваши ответы успешно отправлены.';
            btn.textContent = '✅ Отправлено';
            btn.disabled = true;
            document.getElementById('surveyForm').reset();
        })
        .catch(err => {
            status.className = 'status error';
            status.textContent = '❌ Ошибка отправки: ' + err.message + '. Попробуйте еще раз.';
            btn.disabled = false;
            btn.textContent = '📩 Отправить ответы';
        });
    });
</script>

